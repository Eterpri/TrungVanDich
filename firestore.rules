rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: site_configs
    // Document ID: domain (e.g., 69shuba.com)
    // Fields:
    //   - domain: string
    //   - selectors: map
    //   - charset: string (optional)
    //   - updatedAt: timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "cuongbt.nb@gmail.com" && request.auth.token.email_verified == true));
    }

    match /site_configs/{domain} {
      allow read: if true; // Publicly readable for the crawler
      allow write: if isAdmin(); // Only admins can update selectors
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId && 
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
    }
  }
}
